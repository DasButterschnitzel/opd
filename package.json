{
  "name": "op-epaper-tool",
  "version": "1.0.0",
  "description": "OP-Online ePaper – täglicher Dreieich-Seiten-Download",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "start:headless": "electron . --headless",
    "dist:win": "electron-builder --win --x64"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "pdf-parse": "^1.1.4",
    "playwright-core": "1.49.1",
    "tesseract.js": "^5.1.1"
  },
  "devDependencies": {
    "electron": "31.7.7",
    "electron-builder": "24.13.3"
  },
  "build": {
    "appId": "de.dreieich.op-epaper-tool",
    "productName": "OP ePaper Tool",
    "icon": "assets/icon.ico",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    },
    "files": [
      "main.js",
      "preload.js",
      "core/**/*",
      "renderer/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ]
  }
}
