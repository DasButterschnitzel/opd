{
  "name": "op-epaper-tool",
  "version": "1.0.0",
  "description": "OP-Online ePaper – täglicher Dreieich-Seiten-Download",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "start:headless": "electron . --headless",
    "dist:win": "electron-builder --win --x64"
  },
  "dependencies": {
    "playwright-core": "1.49.1"
  },
  "devDependencies": {
    "electron": "31.7.7",
    "electron-builder": "24.13.3"
  },
  "build": {
    "appId": "de.dreieich.op-epaper-tool",
    "productName": "OP ePaper Tool",
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "main.js",
      "preload.js",
      "core/**/*",
      "renderer/**/*",
      "node_modules/**/*"
    ]
  }
}
